    { "id": "sand",  "field": "/Users/hunglingki/git_projects/web_projects/doodi_world_demo/tmp/std_regen/_tiles/sand_field.png" },
    { "id": "water", "field": "/Users/hunglingki/git_projects/web_projects/doodi_world_demo/tmp/std_regen/_tiles/water_field.png" }
