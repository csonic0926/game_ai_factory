{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://game-ai-factory.local/gameplay/gameplay_design_model.schema.json",
  "title": "Gameplay Design Model",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "primary_progression_driver",
    "player_actions",
    "recent_patterns",
    "design_constraints"
  ],
  "properties": {
    "schema_version": {"const": "gameplay_design_model.v1"},
    "project_id": {"type": "string", "minLength": 1},
    "primary_progression_driver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system_id", "system_kind", "progression_unit", "description", "evidence_refs"],
      "properties": {
        "system_id": {"type": "string", "minLength": 1},
        "system_kind": {"type": "string", "minLength": 1},
        "progression_unit": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "evidence_refs": {"$ref": "#/$defs/evidence_refs"}
      }
    },
    "player_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action_id", "description", "availability", "rewards", "evidence_refs"],
        "properties": {
          "action_id": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "availability": {"type": "string", "minLength": 1},
          "rewards": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["reward_id", "kind", "description"],
              "properties": {
                "reward_id": {"type": "string", "minLength": 1},
                "kind": {"type": "string", "minLength": 1},
                "description": {"type": "string", "minLength": 1}
              }
            }
          },
          "evidence_refs": {"$ref": "#/$defs/evidence_refs"}
        }
      }
    },
    "recent_patterns": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "design_constraints": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  },
  "$defs": {
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "path", "contains"],
        "properties": {
          "role": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "contains": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  }
}
